# ai_newsletter — environment template
#
# Copy this to .env and fill in the secrets. .env is gitignored.
# For local dev, the docker-compose stack provides all the infra at the
# defaults listed here.

# --- HTTP -----------------------------------------------------------------
ADDR=:8080

# --- Postgres -------------------------------------------------------------
DATABASE_URL=postgres://ai_newsletter:ai_newsletter@localhost:5433/ai_newsletter?sslmode=disable

# --- NSQ ------------------------------------------------------------------
# The docker-compose stack exposes nsqd on +1000 ports to avoid colliding
# with a system-wide install.
NSQD_TCP_ADDR=localhost:5150
NSQLOOKUPD_HTTP_ADDR=localhost:5161

# --- OpenAI (curation pipeline) -------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4-mini
OPENAI_IMAGE_MODEL=gpt-image-1.5

# --- Cloudflare R2 (cover image storage) ----------------------------------
# Account id is in your CF dashboard URL. Create an R2 API token with
# Object Read+Write on R2_BUCKET. R2_PUBLIC_BASE_URL is your r2.dev URL or
# a custom domain mapped to the bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev

# --- Firebase (auth) ------------------------------------------------------
# Backend.
FIREBASE_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-service-account.json
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# Frontend (these are intentionally public — they ship in the browser bundle).
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NUXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
# NUXT_PUBLIC_FIREBASE_AUTH_EMULATOR=true
NUXT_PUBLIC_API_BASE=/api/v1
